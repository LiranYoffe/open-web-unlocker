{
	"name": "open-web-unlocker",
	"version": "0.1.0",
	"description": "Fetch public web pages through a configurable fetch/browser pipeline and parse them into structured JSON or clean markdown.",
	"type": "module",
	"packageManager": "bun@1.3.10",
	"bin": {
		"owu": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "rm -rf dist && bun x tsc --project tsconfig.build.json",
		"typecheck": "bun x tsc --noEmit",
		"smoke:cli": "bun dist/index.js --help >/dev/null",
		"pack:dry-run": "bunx npm pack --dry-run",
		"check": "bun run typecheck && bun run build && bun run smoke:cli",
		"test": "bun run check",
		"prepublishOnly": "bun run check"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.3.0"
	},
	"keywords": [
		"web",
		"scraping",
		"parser",
		"cli",
		"mcp",
		"http"
	],
	"license": "MIT",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"camoufox-js": "^0.9.1",
		"commander": "^14.0.3",
		"css-select": "^6.0.0",
		"dom-serializer": "^2.0.0",
		"domhandler": "^5.0.3",
		"domutils": "^3.2.2",
		"hono": "^4.12.5",
		"htmlparser2": "^10.1.0",
		"node-html-markdown": "2.0.0",
		"patchright": "^1.58.2",
		"playwright-core": "^1.58.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10"
	}
}
